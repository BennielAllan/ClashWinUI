<Page
    x:Class="ClashWinUI.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page title -->
        <TextBlock
            Grid.Row="0"
            MaxWidth="1064"
            Margin="36,24,36,0"
            AutomationProperties.HeadingLevel="Level1"
            Style="{StaticResource TitleTextBlockStyle}"
            Text="{x:Bind PageTitle, Mode=OneWay}" />

        <!-- Content -->
        <ScrollViewer
            Grid.Row="1"
            Padding="36,12,36,24"
            VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="1064" Spacing="12">

                <!-- Start error banner -->
                <InfoBar
                    IsOpen="{x:Bind HasStartError, Mode=OneWay}"
                    Severity="Error"
                    Title="{x:Bind StartErrorMessage, Mode=OneWay}"
                    IsClosable="True"
                    Closed="ErrorBar_Closed" />

                <!-- Row 1: Subscription + Current Node -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Subscription Card -->
                    <Button
                        Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{ThemeResource ControlCornerRadius}"
                        Padding="20,16"
                        Click="SubscriptionCard_Click">
                        <StackPanel VerticalAlignment="Center" Spacing="4">
                            <TextBlock
                                Text="{x:Bind ActiveSubscriptionLabel, Mode=OneWay}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock
                                Text="{x:Bind SubscriptionName, Mode=OneWay}"
                                Style="{StaticResource BodyStrongTextBlockStyle}"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Button>

                    <!-- Current Node Card -->
                    <Button
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{ThemeResource ControlCornerRadius}"
                        Padding="20,16"
                        Click="NodeCard_Click">
                        <StackPanel VerticalAlignment="Center" Spacing="4">
                            <TextBlock
                                Text="{x:Bind CurrentNodeLabel, Mode=OneWay}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock
                                Text="{x:Bind CurrentNodeName, Mode=OneWay}"
                                Style="{StaticResource BodyStrongTextBlockStyle}"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Row 2: Network Mode (settings-style rows) -->
                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{ThemeResource ControlCornerRadius}"
                    Padding="20,12">
                    <StackPanel Spacing="0">
                        <TextBlock
                            Text="{x:Bind NetworkModeLabel, Mode=OneWay}"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Margin="0,4,0,8" />

                        <!-- System Proxy row -->
                        <Grid Padding="0,6" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                                <TextBlock
                                    Text="{x:Bind SystemProxyLabel, Mode=OneWay}"
                                    Style="{StaticResource BodyTextBlockStyle}" />
                                <TextBlock
                                    Text="{x:Bind SystemProxyDescLabel, Mode=OneWay}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ToggleSwitch
                                Grid.Column="1"
                                IsOn="{x:Bind IsSystemProxyEnabled, Mode=OneWay}"
                                OnContent=""
                                OffContent=""
                                Toggled="SystemProxy_Toggled"
                                VerticalAlignment="Center"
                                Margin="0" />
                        </Grid>

                        <Rectangle
                            Height="1"
                            Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                            Margin="0,4" />

                        <!-- TUN Mode row -->
                        <Grid Padding="0,6" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                                <TextBlock
                                    Text="{x:Bind TunModeLabel, Mode=OneWay}"
                                    Style="{StaticResource BodyTextBlockStyle}" />
                                <TextBlock
                                    Text="{x:Bind TunModeDescLabel, Mode=OneWay}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ToggleSwitch
                                Grid.Column="1"
                                IsOn="{x:Bind IsTunEnabled, Mode=OneWay}"
                                OnContent=""
                                OffContent=""
                                Toggled="TunMode_Toggled"
                                IsEnabled="{x:Bind IsRunning, Mode=OneWay}"
                                VerticalAlignment="Center"
                                Margin="0" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Row 3: Proxy Mode -->
                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{ThemeResource ControlCornerRadius}"
                    Padding="20,16">
                    <StackPanel Spacing="12">
                        <TextBlock
                            Text="{x:Bind ProxyModeLabel, Mode=OneWay}"
                            Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <RadioButton
                                Content="{x:Bind ModeRuleLabel, Mode=OneWay}"
                                GroupName="HomeProxyMode"
                                IsChecked="{x:Bind IsModeRule, Mode=OneWay}"
                                IsEnabled="{x:Bind IsRunning, Mode=OneWay}"
                                Checked="ModeRule_Checked" />
                            <RadioButton
                                Content="{x:Bind ModeGlobalLabel, Mode=OneWay}"
                                GroupName="HomeProxyMode"
                                IsChecked="{x:Bind IsModeGlobal, Mode=OneWay}"
                                IsEnabled="{x:Bind IsRunning, Mode=OneWay}"
                                Checked="ModeGlobal_Checked" />
                            <RadioButton
                                Content="{x:Bind ModeDirectLabel, Mode=OneWay}"
                                GroupName="HomeProxyMode"
                                IsChecked="{x:Bind IsModeDirect, Mode=OneWay}"
                                IsEnabled="{x:Bind IsRunning, Mode=OneWay}"
                                Checked="ModeDirect_Checked" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Row 4 (last): Mihomo Core Status -->
                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{ThemeResource ControlCornerRadius}"
                    Padding="20,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Ellipse
                                    Width="8" Height="8"
                                    Fill="{x:Bind CoreDotBrush, Mode=OneWay}"
                                    VerticalAlignment="Center" />
                                <TextBlock
                                    Text="Mihomo"
                                    Style="{StaticResource BodyStrongTextBlockStyle}" />
                            </StackPanel>
                            <TextBlock
                                Text="{x:Bind CoreStatusText, Mode=OneWay}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}" />
                        </StackPanel>

                        <StackPanel
                            Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                            <ProgressRing
                                IsActive="{x:Bind IsBusy, Mode=OneWay}"
                                Visibility="{x:Bind BusyVisibility, Mode=OneWay}"
                                Width="20" Height="20" />
                            <Button
                                Content="{x:Bind CoreButtonLabel, Mode=OneWay}"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="CoreToggle_Click"
                                IsEnabled="{x:Bind IsNotBusy, Mode=OneWay}"
                                Padding="16,8" />
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
