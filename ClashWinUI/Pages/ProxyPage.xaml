<Page
    x:Class="ClashWinUI.Pages.ProxyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:ClashWinUI.Models"
    mc:Ignorable="d"
    Background="{ThemeResource LayerFillColorDefaultBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page title -->
        <TextBlock
            Grid.Row="0"
            Margin="36,24,36,0"
            AutomationProperties.HeadingLevel="Level1"
            Style="{StaticResource TitleTextBlockStyle}"
            Text="{x:Bind PageTitle, Mode=OneWay}" />

        <!-- Command bar: mode selector + refresh + test all -->
        <Grid Grid.Row="1" Margin="24,8,24,0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Proxy mode radio group -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <RadioButton
                    x:Name="ModeRuleBtn"
                    Content="{x:Bind ModeRuleLabel, Mode=OneWay}"
                    GroupName="ProxyMode"
                    IsChecked="{x:Bind IsModeRule, Mode=OneWay}"
                    Checked="ModeRule_Checked" />
                <RadioButton
                    x:Name="ModeGlobalBtn"
                    Content="{x:Bind ModeGlobalLabel, Mode=OneWay}"
                    GroupName="ProxyMode"
                    IsChecked="{x:Bind IsModeGlobal, Mode=OneWay}"
                    Checked="ModeGlobal_Checked" />
                <RadioButton
                    x:Name="ModeDirectBtn"
                    Content="{x:Bind ModeDirectLabel, Mode=OneWay}"
                    GroupName="ProxyMode"
                    IsChecked="{x:Bind IsModeDirect, Mode=OneWay}"
                    Checked="ModeDirect_Checked" />
            </StackPanel>

            <!-- Refresh -->
            <Button
                Grid.Column="2"
                Style="{StaticResource TransparentIconButtonStyle}"
                ToolTipService.ToolTip="{x:Bind RefreshLabel, Mode=OneWay}"
                Click="RefreshButton_Click"
                Width="36" Height="36">
                <FontIcon
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    Glyph="&#xE72C;"
                    FontSize="14" />
            </Button>

            <!-- Test All -->
            <Button
                Grid.Column="3"
                Content="{x:Bind TestAllLabel, Mode=OneWay}"
                Style="{StaticResource AccentButtonStyle}"
                Click="TestAllButton_Click"
                Padding="12,6"
                IsEnabled="{x:Bind IsNotTesting, Mode=OneWay}" />
        </Grid>

        <!-- Content area -->
        <Grid Grid.Row="2">

            <!-- Not running banner -->
            <InfoBar
                IsOpen="{x:Bind IsNotRunning, Mode=OneWay}"
                Severity="Warning"
                Title="{x:Bind NotRunningMessage, Mode=OneWay}"
                Margin="24,8,24,0"
                IsClosable="False"
                VerticalAlignment="Top" />

            <!-- Loading spinner -->
            <ProgressRing
                IsActive="{x:Bind IsLoading, Mode=OneWay}"
                Visibility="{x:Bind LoadingVisibility, Mode=OneWay}"
                Width="40" Height="40"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" />

            <!-- Groups list -->
            <ScrollViewer
                x:Name="GroupsScrollViewer"
                Padding="24,8,24,24"
                Visibility="{x:Bind GroupsVisibility, Mode=OneWay}"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
                <ItemsRepeater
                    x:Name="GroupsRepeater"
                    ItemsSource="{x:Bind ProxyGroups, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="8" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:ProxyGroup">
                            <Border
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="0">
                                <StackPanel>
                                    <!-- Group header -->
                                    <Grid Padding="16,12" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock
                                                    Text="{x:Bind Name, Mode=OneWay}"
                                                    Style="{StaticResource BodyStrongTextBlockStyle}" />
                                                <Border
                                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                    CornerRadius="4" Padding="6,2"
                                                    VerticalAlignment="Center">
                                                    <TextBlock
                                                        Text="{x:Bind TypeLabel, Mode=OneWay}"
                                                        FontSize="11"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock
                                                Text="{x:Bind Now, Mode=OneWay}"
                                                FontSize="12"
                                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>

                                        <!-- Testing ring -->
                                        <ProgressRing
                                            Grid.Column="1"
                                            IsActive="{x:Bind IsTesting, Mode=OneWay}"
                                            Visibility="{x:Bind TestRingVisibility, Mode=OneWay}"
                                            Width="18" Height="18"
                                            VerticalAlignment="Center" />

                                        <!-- Test button -->
                                        <Button
                                            Grid.Column="2"
                                            Tag="{x:Bind}"
                                            Style="{StaticResource TransparentIconButtonStyle}"
                                            Visibility="{x:Bind TestButtonVisibility, Mode=OneWay}"
                                            ToolTipService.ToolTip="Test speed"
                                            Click="GroupTest_Click"
                                            Width="32" Height="32">
                                            <FontIcon
                                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                Glyph="&#xE9F3;"
                                                FontSize="13" />
                                        </Button>

                                        <!-- Expand chevron -->
                                        <Button
                                            Grid.Column="3"
                                            Tag="{x:Bind}"
                                            Style="{StaticResource TransparentIconButtonStyle}"
                                            Click="GroupExpand_Click"
                                            Width="32" Height="32">
                                            <FontIcon
                                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                Glyph="{x:Bind ChevronGlyph, Mode=OneWay}"
                                                FontSize="11" />
                                        </Button>
                                    </Grid>

                                    <!-- Nodes list (visible when expanded) -->
                                    <ItemsRepeater
                                        ItemsSource="{x:Bind Nodes, Mode=OneWay}"
                                        Visibility="{x:Bind ExpandedVisibility, Mode=OneWay}"
                                        Margin="0,0,0,8">
                                        <ItemsRepeater.Layout>
                                            <StackLayout Spacing="0" />
                                        </ItemsRepeater.Layout>
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate x:DataType="models:ProxyNode">
                                                <Grid
                                                    Tag="{x:Bind}"
                                                    Padding="40,6,16,6"
                                                    ColumnSpacing="8"
                                                    PointerPressed="Node_PointerPressed">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock
                                                        Grid.Column="0"
                                                        Text="{x:Bind Name, Mode=OneWay}"
                                                        Style="{StaticResource BodyTextBlockStyle}"
                                                        TextTrimming="CharacterEllipsis"
                                                        VerticalAlignment="Center" />

                                                    <!-- Testing ring -->
                                                    <ProgressRing
                                                        Grid.Column="1"
                                                        IsActive="{x:Bind IsTesting, Mode=OneWay}"
                                                        Visibility="{x:Bind TestingVisibility, Mode=OneWay}"
                                                        Width="14" Height="14"
                                                        VerticalAlignment="Center" />

                                                    <!-- Delay badge -->
                                                    <Border
                                                        Grid.Column="2"
                                                        CornerRadius="4"
                                                        Padding="6,2"
                                                        Visibility="{x:Bind DelayVisibility, Mode=OneWay}"
                                                        VerticalAlignment="Center">
                                                        <TextBlock
                                                            Text="{x:Bind DelayDisplay, Mode=OneWay}"
                                                            FontSize="11"
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>

            <!-- Empty state -->
            <StackPanel
                Visibility="{x:Bind EmptyVisibility, Mode=OneWay}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">
                <FontIcon
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    Glyph="&#xEC3F;"
                    FontSize="48"
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBlock
                    Text="{x:Bind NoGroupsMessage, Mode=OneWay}"
                    Style="{StaticResource BodyTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
