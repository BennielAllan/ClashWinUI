<Page
    x:Class="ClashWinUI.Pages.ProxyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:ClashWinUI.Models"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page title -->
        <TextBlock
            Grid.Row="0"
            MaxWidth="1064"
            Margin="36,24,36,0"
            AutomationProperties.HeadingLevel="Level1"
            Style="{StaticResource TitleTextBlockStyle}"
            Text="{x:Bind PageTitle, Mode=OneWay}" />

        <!-- Command bar: refresh + test all -->
        <CommandBar
            Grid.Row="1"
            Margin="24,4,36,0"
            HorizontalAlignment="Right"
            DefaultLabelPosition="Right">
            <AppBarButton
                x:Name="RefreshAppBarButton"
                Label="{x:Bind RefreshLabel, Mode=OneWay}"
                Click="RefreshButton_Click"
                IsEnabled="{x:Bind IsNotRefreshing, Mode=OneWay}">
                <AppBarButton.Icon>
                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE72C;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton
                x:Name="TestAllAppBarButton"
                Label="{x:Bind TestAllLabel, Mode=OneWay}"
                Click="TestAllButton_Click"
                IsEnabled="{x:Bind IsNotTesting, Mode=OneWay}">
                <AppBarButton.Icon>
                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xF42F;" />
                </AppBarButton.Icon>
            </AppBarButton>
        </CommandBar>

        <!-- Content area -->
        <Grid Grid.Row="2">

            <!-- Not running banner -->
            <InfoBar
                IsOpen="{x:Bind IsNotRunning, Mode=OneWay}"
                Severity="Warning"
                Title="{x:Bind NotRunningMessage, Mode=OneWay}"
                Margin="36,8,36,0"
                IsClosable="False"
                VerticalAlignment="Top" />

            <!-- Load error banner -->
            <InfoBar
                IsOpen="{x:Bind HasLoadError, Mode=OneWay}"
                Severity="Error"
                Title="{x:Bind LoadError, Mode=OneWay}"
                Margin="36,8,36,0"
                IsClosable="False"
                VerticalAlignment="Top" />

            <!-- Loading spinner -->
            <ProgressRing
                IsActive="{x:Bind IsLoading, Mode=OneWay}"
                Visibility="{x:Bind LoadingVisibility, Mode=OneWay}"
                Width="40" Height="40"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" />

            <!-- Groups list -->
            <ScrollViewer
                x:Name="GroupsScrollViewer"
                Padding="36,8,36,24"
                Visibility="{x:Bind GroupsVisibility, Mode=OneWay}"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
                <ItemsRepeater
                    x:Name="GroupsRepeater"
                    MaxWidth="1064"
                    ItemsSource="{x:Bind ProxyGroups, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="4" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:ProxyGroup">
                            <Expander
                                IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch">

                                <!-- Group header -->
                                <Expander.Header>
                                    <Grid ColumnSpacing="8" Margin="0,0,4,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock
                                                    Text="{x:Bind Name, Mode=OneTime}"
                                                    Style="{StaticResource BodyStrongTextBlockStyle}" />
                                                <Border
                                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                    CornerRadius="4" Padding="6,2"
                                                    VerticalAlignment="Center">
                                                    <TextBlock
                                                        Text="{x:Bind TypeLabel, Mode=OneTime}"
                                                        FontSize="11"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Testing ring -->
                                        <ProgressRing
                                            Grid.Column="1"
                                            IsActive="{x:Bind IsTesting, Mode=OneWay}"
                                            Visibility="{x:Bind TestRingVisibility, Mode=OneWay}"
                                            Width="18" Height="18"
                                            VerticalAlignment="Center" />

                                        <!-- Test button -->
                                        <Button
                                            Grid.Column="2"
                                            Tag="{x:Bind}"
                                            Style="{StaticResource TransparentIconButtonStyle}"
                                            Visibility="{x:Bind TestButtonVisibility, Mode=OneWay}"
                                            ToolTipService.ToolTip="Test speed"
                                            Click="GroupTest_Click"
                                            Width="32" Height="32">
                                            <FontIcon
                                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                Glyph="&#xF42F;"
                                                FontSize="13" />
                                        </Button>
                                    </Grid>
                                </Expander.Header>

                                <!-- Node list -->
                                <ItemsRepeater
                                    ItemsSource="{x:Bind NodeViews, Mode=OneWay}"
                                    Margin="0">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Spacing="2" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="models:ProxyNodeView">
                                            <Button
                                                Tag="{x:Bind}"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="0,6"
                                                Click="Node_Click">
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="20" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Selected indicator dot -->
                                                    <Ellipse
                                                        Grid.Column="0"
                                                        Width="6" Height="6"
                                                        Fill="{ThemeResource AccentFillColorDefaultBrush}"
                                                        Visibility="{x:Bind SelectedDotVisibility, Mode=OneWay}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center" />

                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Text="{x:Bind Name, Mode=OneTime}"
                                                        Style="{StaticResource BodyTextBlockStyle}"
                                                        TextTrimming="CharacterEllipsis"
                                                        VerticalAlignment="Center" />

                                                    <!-- Testing ring -->
                                                    <ProgressRing
                                                        Grid.Column="2"
                                                        IsActive="{x:Bind IsTesting, Mode=OneWay}"
                                                        Visibility="{x:Bind TestingVisibility, Mode=OneWay}"
                                                        Width="14" Height="14"
                                                        VerticalAlignment="Center" />

                                                    <!-- Delay badge -->
                                                    <Border
                                                        Grid.Column="3"
                                                        CornerRadius="4"
                                                        Padding="6,2"
                                                        Visibility="{x:Bind DelayVisibility, Mode=OneWay}"
                                                        VerticalAlignment="Center">
                                                        <TextBlock
                                                            Text="{x:Bind DelayDisplay, Mode=OneWay}"
                                                            FontSize="11"
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    </Border>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>

                            </Expander>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>

            <!-- Empty state -->
            <StackPanel
                Visibility="{x:Bind EmptyVisibility, Mode=OneWay}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">
                <FontIcon
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    Glyph="&#xEC3F;"
                    FontSize="48"
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBlock
                    Text="{x:Bind NoGroupsMessage, Mode=OneWay}"
                    Style="{StaticResource BodyTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
